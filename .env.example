# MongoDB configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=intelligent_bug_management_contributor_intel

# GitHub API
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_API_BASE_URL=https://api.github.com

# Default repository context
DEFAULT_REPOSITORY_OWNER=pandas-dev
DEFAULT_REPOSITORY_NAME=pandas
DEFAULT_REPOSITORY_URL=https://github.com/pandas-dev/pandas

# LLM provider configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-3-27b-it

# Prompt/context optimization for large commit histories
LLM_PROMPT_CHAR_BUDGET=12000
LLM_MAX_EVIDENCE_ITEMS=20
LLM_RECENT_MESSAGES_LIMIT=25

# Sync defaults
DEFAULT_SYNC_PAGES=5
DEFAULT_PAGE_SIZE=100
